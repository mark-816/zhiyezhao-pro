/**
 * 职业照Pro - 我的页面样式
 */

.zp-my-page {
  min-height: 100vh;
  padding-bottom: var(--zp-spacing-2xl);
}

/* ===== 用户信息 ===== */
.zp-my-user {
  padding: var(--zp-spacing-lg);
}

.zp-my-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.zp-my-avatar-img {
  width: 100%;
  height: 100%;
}

.zp-my-avatar-default {
  background: var(--zp-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.zp-my-login-hint {
  cursor: pointer;
}

/* ===== 统计卡片 ===== */
.zp-my-stats {
  gap: var(--zp-spacing-md);
}

.zp-my-stat-card {
  flex: 1;
  padding: var(--zp-spacing-md) var(--zp-spacing-sm);
  margin-bottom: 0;
}

/* ===== 历史记录 ===== */
.zp-my-history-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--zp-spacing-md);
}

.zp-my-history-item {
  border-radius: var(--zp-radius-md);
  overflow: hidden;
  transition: all 0.2s;
}

.zp-my-history-item:active {
  transform: scale(0.95);
}

.zp-my-history-placeholder {
  width: 100%;
  aspect-ratio: 3 / 4;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--zp-radius-md);
}

.zp-my-history-time {
  text-align: center;
  margin-top: 6rpx;
}

/* ===== 设置列表 ===== */
.zp-my-settings {
  padding-bottom: var(--zp-spacing-lg);
}

.zp-my-setting-item {
  padding: var(--zp-spacing-md) 0;
  border-bottom: 1rpx solid var(--zp-border-light);
}

.zp-my-setting-item:last-child {
  border-bottom: none;
}

.zp-my-setting-icon {
  width: 56rpx;
  height: 56rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--zp-bg-secondary);
  border-radius: var(--zp-radius-sm);
  margin-right: var(--zp-spacing-md);
  flex-shrink: 0;
}
