/**
 * 职业照Pro - 首页样式
 * @brand 职业照Pro
 */

/* ===== Hero 区域 ===== */
.zp-index-hero {
  position: relative;
  height: 480rpx;
  overflow: hidden;
}

.zp-index-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--zp-primary-dark) 0%, var(--zp-primary) 40%, var(--zp-primary-light) 100%);
}

.zp-index-hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding-top: 120rpx;
}

.zp-index-brand-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: zp-scaleIn 0.6s ease-out;
}

.zp-index-title {
  letter-spacing: 4rpx;
  animation: zp-slideUp 0.6s ease-out;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.zp-index-subtitle {
  margin-top: 16rpx;
  opacity: 0.85;
  animation: zp-slideUp 0.6s ease-out 0.15s both;
  letter-spacing: 2rpx;
}

/* ===== CTA 按钮区 ===== */
.zp-index-cta {
  padding: var(--zp-spacing-lg) var(--zp-spacing-lg) 0;
  margin-top: -40rpx;
  position: relative;
  z-index: 3;
}

.zp-index-cta-tip {
  opacity: 0.7;
}

/* ===== 特色卖点 ===== */
.zp-index-features {
  margin-top: var(--zp-spacing-lg);
}

.zp-index-feature-list {
  display: flex;
  gap: var(--zp-spacing-md);
}

.zp-index-feature-card {
  flex: 1;
  text-align: center;
  padding: var(--zp-spacing-lg) var(--zp-spacing-sm);
}

.zp-index-feature-icon {
  font-size: 56rpx;
  margin-bottom: var(--zp-spacing-sm);
}

.zp-index-feature-title {
  margin-bottom: 8rpx;
}

.zp-index-feature-desc {
  line-height: 1.4;
}

/* ===== 底部操作区 ===== */
.zp-index-actions {
  padding-bottom: var(--zp-spacing-lg);
}

.zp-index-action-card {
  padding: var(--zp-spacing-lg);
  border-radius: var(--zp-radius-lg);
}

/* ===== 动画增强 ===== */
.zp-index-feature-card:nth-child(1) { animation-delay: 0.1s; }
.zp-index-feature-card:nth-child(2) { animation-delay: 0.2s; }
.zp-index-feature-card:nth-child(3) { animation-delay: 0.3s; }
