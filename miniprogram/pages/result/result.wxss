/**
 * 职业照Pro - 结果页样式
 */

.zp-result-page {
  min-height: 100vh;
  padding-bottom: var(--zp-spacing-2xl);
}

.zp-result-header {
  padding-top: var(--zp-spacing-lg);
}

/* ===== 大图预览 ===== */
.zp-result-preview-image-wrap {
  position: relative;
  width: 100%;
  border-radius: var(--zp-radius-xl);
  overflow: hidden;
  box-shadow: var(--zp-shadow-md);
}

.zp-result-placeholder-img {
  width: 100%;
  aspect-ratio: 3 / 4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.zp-result-placeholder-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--zp-radius-xl);
}

/* 左右切换热区 */
.zp-result-swipe-left,
.zp-result-swipe-right {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.zp-result-preview-image-wrap:hover .zp-result-swipe-left,
.zp-result-preview-image-wrap:hover .zp-result-swipe-right {
  opacity: 1;
}

.zp-result-swipe-left { left: 0; }
.zp-result-swipe-right { right: 0; }

.zp-result-arrow {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  text-align: center;
  line-height: 60rpx;
  color: var(--zp-text-primary);
}

/* ===== 操作按钮行 ===== */
.zp-result-action-row {
  padding: var(--zp-spacing-md) 0;
}

.zp-result-action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--zp-spacing-sm);
  border-radius: var(--zp-radius-md);
  transition: all 0.2s;
}

.zp-result-action-btn:active {
  background: var(--zp-bg-tertiary);
  transform: scale(0.95);
}

.zp-result-action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.zp-result-action-label {
  font-size: var(--zp-font-sm);
  color: var(--zp-text-secondary);
  font-weight: 500;
}

/* ===== 缩略图区域 ===== */
.zp-result-thumb-scroll {
  overflow: hidden;
  white-space: nowrap;
}

.zp-result-thumb-list {
  display: flex;
  gap: var(--zp-spacing-md);
  padding: var(--zp-spacing-sm) 0;
}

.zp-result-thumb-item {
  flex-shrink: 0;
  width: 140rpx;
  position: relative;
  border-radius: var(--zp-radius-md);
  overflow: hidden;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.zp-result-thumb-item.active {
  border-color: var(--zp-primary);
}

.zp-result-thumb-placeholder {
  width: 140rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--zp-radius-sm);
}

.zp-result-thumb-num {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  font-size: 18rpx;
  color: var(--zp-text-tertiary);
}

/* ===== 底部 ===== */
.zp-result-footer {
  padding-bottom: calc(env(safe-area-inset-bottom, 20rpx) + var(--zp-spacing-lg));
}
