<!-- 职业照Pro - 结果页 -->
<view class="zp-result-page">

  <!-- ===== 顶部导航提示 ===== -->
  <view class="zp-result-header zp-ph-lg zp-pt-lg">
    <view class="zp-flex zp-items-center zp-gap-sm">
      <text class="zp-text-xl">✅</text>
      <text class="zp-text-lg zp-font-bold">生成完成</text>
    </view>
  </view>

  <!-- ===== 大图预览区 ===== -->
  <view class="zp-result-preview zp-ph-lg zp-mt-md" wx:if="{{currentResult}}">
    <view class="zp-result-preview-header zp-flex zp-flex-between zp-mb-sm">
      <view class="zp-text-sm zp-text-secondary">{{currentIndex + 1}} / {{results.length}}</view>
      <view class="zp-text-sm zp-text-secondary">{{currentResult.desc}}</view>
    </view>

    <view class="zp-result-preview-image-wrap">
      <!-- 占位图 - 用渐变背景模拟 -->
      <view class="zp-result-placeholder-img">
        <view class="zp-result-placeholder-inner" style="background: linear-gradient(135deg, var(--zp-primary-bg), #DBEAFE);">
          <view class="zp-text-3xl">📸</view>
          <view class="zp-text-sm zp-text-secondary zp-mt-sm">职业照预设 {{currentIndex + 1}}</view>
        </view>
      </view>

      <!-- 左右切换热区 -->
      <view class="zp-result-swipe-left" bindtap="switchResult" data-direction="prev">
        <text class="zp-result-arrow zp-text-xl">‹</text>
      </view>
      <view class="zp-result-swipe-right" bindtap="switchResult" data-direction="next">
        <text class="zp-result-arrow zp-text-xl">›</text>
      </view>
    </view>
  </view>

  <!-- ===== 操作按钮行 ===== -->
  <view class="zp-result-actions zp-ph-lg zp-mt-lg">
    <view class="zp-result-action-row zp-flex zp-flex-between zp-gap-sm">
      <view class="zp-result-action-btn" bindtap="saveToAlbum">
        <view class="zp-result-action-icon">💾</view>
        <view class="zp-result-action-label">保存</view>
      </view>
      <view class="zp-result-action-btn" bindtap="regenerateWithNewBg">
        <view class="zp-result-action-icon">🔄</view>
        <view class="zp-result-action-label">换背景</view>
      </view>
      <view class="zp-result-action-btn" bindtap="onShare">
        <view class="zp-result-action-icon">📤</view>
        <view class="zp-result-action-label">分享</view>
      </view>
      <view class="zp-result-action-btn" bindtap="toggleFavorite">
        <view class="zp-result-action-icon">{{isFavorited ? '❤️' : '🤍'}}</view>
        <view class="zp-result-action-label">{{isFavorited ? '已收藏' : '收藏'}}</view>
      </view>
    </view>
  </view>

  <!-- ===== 缩略图横向滚动选择 ===== -->
  <view class="zp-result-thumbnails zp-mt-lg zp-ph-lg">
    <view class="zp-section-title">所有结果</view>
    <scroll-view class="zp-result-thumb-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="zp-result-thumb-list">
        <view
          class="zp-result-thumb-item {{currentIndex === index ? 'active' : ''}}"
          wx:for="{{results}}"
          wx:key="id"
          data-index="{{index}}"
          bindtap="selectThumbnail"
        >
          <view class="zp-result-thumb-placeholder" style="background: linear-gradient(135deg, var(--zp-primary-bg), #DBEAFE);">
            <text class="zp-text-lg">📸</text>
          </view>
          <view class="zp-result-thumb-num">{{index + 1}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 底部操作 ===== -->
  <view class="zp-result-footer zp-ph-lg zp-mt-lg zp-safe-area-bottom">
    <button class="zp-btn zp-btn-primary zp-btn-block" bindtap="goHome">
      🏠 返回首页
    </button>
  </view>

</view>
