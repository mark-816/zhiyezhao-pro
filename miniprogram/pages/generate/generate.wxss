/**
 * 职业照Pro - 生成页样式
 */

.zp-generate-page {
  min-height: 100vh;
  padding: var(--zp-spacing-2xl);
}

/* ===== 动态图标 ===== */
.zp-generate-icon {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.zp-generate-icon-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid var(--zp-primary-bg);
  border-top-color: var(--zp-primary);
  animation: zp-rotate 1.5s linear infinite;
}

.zp-generate-icon-ring-2 {
  width: 80%;
  height: 80%;
  border-width: 4rpx;
  border-top-color: var(--zp-accent);
  animation-duration: 2s;
  animation-direction: reverse;
}

.zp-generate-icon-inner {
  font-size: 56rpx;
  z-index: 2;
}

/* ===== 进度条 ===== */
.zp-generate-progress-bar {
  width: 350rpx;
  height: 8rpx;
  background: var(--zp-bg-tertiary);
  border-radius: var(--zp-radius-full);
  margin-top: var(--zp-spacing-lg);
  overflow: hidden;
}

.zp-generate-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--zp-primary), var(--zp-accent));
  border-radius: var(--zp-radius-full);
  transition: width 0.15s ease-out;
}

/* ===== 生成信息卡片 ===== */
.zp-generate-info {
  width: 320rpx;
  padding: var(--zp-spacing-md) var(--zp-spacing-lg);
  text-align: left;
}

/* ===== 完成状态 ===== */
.zp-generate-complete {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.zp-generate-complete-icon {
  font-size: 100rpx;
}
